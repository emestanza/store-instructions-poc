# Environment Variables Configuration

## Local Development
DATABASE_PATH=./database.sqlite
PORT=3000
NODE_ENV=development

## Production (Render.com)
# These are set automatically by Render or via dashboard
# DATABASE_PATH=/opt/render/project/src/data/store-instructions.db
# PORT=3000
# NODE_ENV=production
# RENDER=true (set automatically)
# RENDER_DISK_PATH=/opt/render/project/src/data (set automatically)

## Production (Railway.app)
# DATABASE_PATH=/app/data/store-instructions.db
# PORT=3000
# NODE_ENV=production

## Production (Fly.io)
# DATABASE_PATH=/data/store-instructions.db
# PORT=3000
# NODE_ENV=production
